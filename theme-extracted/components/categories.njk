<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="py-6 lg:py-8">
    {% if properties.title %}
      <div class="flex items-center justify-center mb-6 md:mb-8 lg:mb-10">
        <div class="inline-block">
          <h2 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl tracking-tight lux-heading">
            {{ properties.title | renderString }}
          </h2>
        </div>
      </div>
    {% endif %}

    <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
      {% for category in categories %}
        <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]">
          <a
            class="block lux-card group overflow-hidden"
            href="{{ category.url }}"
          >
            <div class="relative overflow-hidden">
              {% if category.image_url %}
                <img src="{{ category.image_url }}" class="w-full aspect-video object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              {% else %}
                <div class="flex justify-center items-center text-lux-blue/30 aspect-video bg-gradient-to-br from-lux-blue/5 to-lux-purple/5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-20" viewBox="0 0 256 256">
                    <path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"/>
                  </svg>
                </div>
              {% endif %}
              <div class="absolute inset-0 bg-gradient-to-t from-lux-n-950/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-300"></div>
            </div>
            <div class="p-5">
              <h3 class="text-base font-semibold uppercase tracking-wide truncate mb-1 text-t-primary">
                {{ category.name }}
              </h3>
              <p class="text-sm text-t-primary/50 line-clamp-2 mb-3 leading-relaxed">
                {{ category.description }}
              </p>
              <span class="inline-flex items-center gap-1 text-xs text-lux-blue-light font-semibold uppercase tracking-wider transition-all duration-200 group-hover:gap-2">
                View Products
                <svg class="size-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><path fill="currentColor" d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10z"/></svg>
              </span>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
