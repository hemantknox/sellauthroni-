{% set containerHeightClassMap = {
  'short': '',
  'medium': 'min-h-[60vh]',
  'tall': 'min-h-[calc(100vh-112px)]'
} %}

{% set containerHeightClass = containerHeightClassMap[properties.height] %}

{% set heroAlignClassMap = {
  'left': 'flex-col md:flex-row md:justify-between',
  'center': 'flex-col',
  'right': 'flex-col md:flex-row-reverse md:justify-between'
} %}

{% set hcClass = heroAlignClassMap[properties.alignment] %}

{% set textWidthClassMap = {
  'small': 'max-w-md',
  'medium': 'max-w-xl',
  'large': 'max-w-3xl',
  'full': ''
} %}

{% set textAlignClassMap = {
  'left': 'text-left',
  'center': 'mx-auto text-center',
  'right': 'text-right'
} %}

{% set textClass = textWidthClassMap[properties.text_width] ~ ' ' ~ textAlignClassMap[properties.alignment] %}

{% set buttonAlignClassMap = {
  'left': 'justify-start',
  'center': 'justify-center',
  'right': 'justify-end'
} %}

{% set buttonClass = buttonAlignClassMap[properties.alignment] %}

{% set imageAlignClassMap = {
  'left': 'justify-start',
  'center': 'justify-center',
  'right': 'justify-end'
} %}

{% set imageClass = imageAlignClassMap[properties.alignment] %}

<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="relative flex justify-center items-center py-20 {{ containerHeightClass }} overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(var(--lux-blue), 0.08) 0%, transparent 70%);"></div>
    <div class="container relative flex gap-12 items-center px-4 {{ hcClass }} z-10">
      <div class="flex flex-col gap-4 {{ textClass }} animate-lux-fade-up">
        {% if properties.title %}
          <h1 class="text-4xl font-bold text-t-primary mb-3 leading-tight md:text-5xl lg:text-6xl tracking-tight">
            {{ properties.title | renderString }}
          </h1>
        {% endif %}
        {% if properties.subtitle %}
          <p class="text-base text-t-primary/60 mb-3 md:text-lg lg:text-xl leading-relaxed">
            {{ properties.subtitle | renderString }}
          </p>
        {% endif %}
        {% if properties.show_searchbar %}
          {% render_snippet "searchbar.njk", alignment=properties.alignment %}
        {% endif %}
        {% if properties.buttons and properties.buttons.length > 0 %}
          <div class="flex flex-wrap items-center gap-4 mt-6 {{ buttonClass }}">
            {% render_snippet "buttons.njk", buttons=properties.buttons %}
          </div>
        {% endif %}
      </div>
      {% if properties.side_image %}
        <div class="flex items-center min-w-md {{ imageClass }} animate-lux-float">
          <img src="{{ properties.side_image | imageUrl }}" alt="" class="max-w-full rounded-lux-lg shadow-lux-lg" />
        </div>
      {% endif %}
    </div>
  </div>
</section>
