{% set title_to_use = properties.default_title %}
{% if category and properties.category_title %}
  {% set title_to_use = properties.category_title %}
{% endif %}

<section
  class="component"
  data-component-id="{{ componentId }}"
  x-data="{
    openGroupModalId: null,
    filtersModalOpen: false,
    openGroupModal(id) {
      this.openGroupModalId = id;
      document.body.style.overflow = 'hidden';
    },
    closeGroupModal() {
      this.openGroupModalId = null;
      document.body.style.overflow = 'auto';
    },
    openFiltersModal() {
      this.filtersModalOpen = true;
      document.body.style.overflow = 'hidden';
    },
    closeFiltersModal() {
      this.filtersModalOpen = false;
      document.body.style.overflow = 'auto';
    },
    submitForm() {
      const form = event.target;
      const inputs = form.querySelectorAll('input, select, textarea');
      inputs.forEach(input => {
        if (!input.value) {
          input.disabled = true;
        }
      });
      form.submit();
    }
  }"
>
  <div class="py-6 lg:py-8">
    {% if title_to_use %}
      <div class="flex items-center justify-center mb-6 md:mb-8 lg:mb-10">
        <div class="inline-block">
          <h1 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl tracking-tight lux-heading">
            {{ title_to_use | renderString }}
          </h1>
        </div>
      </div>
    {% endif %}

    <div class="lg:hidden mb-6">
      <button
        x-on:click="openFiltersModal"
        class="btn-primary w-full"
      >
        <i class="fa fa-sliders-h"></i>
        <span>Filters</span>
      </button>
    </div>
  
    <div class="grid lg:grid-cols-[280px_1fr] gap-6 lg:gap-8">
      <aside class="hidden lg:block">
        <div class="sticky top-8 glass rounded-lux-lg p-5 lg:p-6 text-t-primary">
          <form x-on:submit.prevent="submitForm">
            <div class="mb-5 pb-5 border-b border-white/[0.06] space-y-5">
              <div>
                <label class="block mb-3 text-sm font-semibold uppercase tracking-wider text-t-primary/70">
                  Categories
                </label>
                <div class="space-y-1">
                  <a
                    href="{{ '/products' | shopUrl }}"
                    class="text-sm text-t-primary/70 py-2.5 px-4 block w-full rounded-lux-sm border border-transparent transition-all duration-200 hover:bg-white/[0.04] hover:text-t-primary {% if not category %}bg-lux-blue/10 !border-lux-blue/20 text-lux-blue-light{% endif %}"
                  >
                    All Categories
                  </a>
                  {% for cat in category_links %}
                    <a
                      href="{{ cat.url }}"
                      class="text-sm text-t-primary/70 py-2.5 px-4 block w-full rounded-lux-sm border border-transparent transition-all duration-200 hover:bg-white/[0.04] hover:text-t-primary {% if category and category.id == cat.id %}bg-lux-blue/10 !border-lux-blue/20 text-lux-blue-light{% endif %}"
                      style="padding-left: {{ (cat.depth * 12 + 16) }}px"
                    >
                      {{ cat.name }}
                    </a>
                  {% endfor %}
                </div>
              </div>
              <div>
                <label for="filters[keyword]" class="block mb-3 text-sm font-semibold uppercase tracking-wider text-t-primary/70">
                  Keyword
                </label>
                <input
                  type="text"
                  name="filters[keyword]"
                  id="filters[keyword]"
                  value="{{ filters.keyword }}"
                  placeholder="Search..."
                  class="lux-input"
                />
              </div>
              <div>
                <label class="block mb-3 text-sm font-semibold uppercase tracking-wider text-t-primary/70">
                  Price Range
                </label>
                <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="lux-input pr-10"
                    />
                    <span class="absolute top-1/2 right-3 -translate-y-1/2 text-t-primary/40 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="lux-input pr-10"
                    />
                    <span class="absolute top-1/2 right-3 -translate-y-1/2 text-t-primary/40 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div class="space-y-3">
              <button type="submit" class="btn-primary w-full">
                <span>Apply Filters</span>
                <i class="fa fa-arrow-right"></i>
              </button>
              <a
                href="{{ '/products' | shopUrl }}"
                class="btn-outline w-full"
              >
                <span>Reset</span>
                <i class="fa fa-rotate-left"></i>
              </a>
            </div>
          </form>
        </div>
      </aside>

      <div class="min-w-0">
        {% if items.length > 0 %}
          <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
            {% for item in items %}
              {% if item.type == 'group' or not item.group_id %}
                <div class="w-full sm:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]">
                  {% render_snippet "product-card.njk", product=item %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="text-center py-16">
            <i class="fa fa-box-open text-6xl text-t-primary/20 mb-4"></i>
            <p class="text-t-primary/50 text-base">
              No products found matching your criteria.
            </p>
          </div>
        {% endif %}

        {% if items_paginator.last_page > 1 %}
          <div class="mt-8">
            {% render_snippet "pagination.njk", paginator=items_paginator %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div
    x-cloak
    x-show="filtersModalOpen"
    class="fixed inset-0 z-50 overflow-y-auto lg:hidden"
  >
    <div class="flex items-center justify-center min-h-screen p-4 text-center">
      <div
        x-show="filtersModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="closeFiltersModal()"
        class="fixed inset-0 lux-modal-backdrop"
      ></div>
      <div
        x-show="filtersModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        class="inline-block w-full max-w-lg max-h-[85vh] overflow-y-auto glass rounded-lux-lg transform"
      >
        <div class="overflow-hidden text-t-primary text-left p-5 md:p-6">
          <div class="flex items-start justify-between gap-4 mb-6">
            <h3 class="text-xl font-bold tracking-tight">
              Filters
            </h3>
            <button @click="closeFiltersModal()" class="flex items-center justify-center size-9 rounded-lg text-t-primary/60 bg-white/[0.03] border border-white/[0.06] transition-all duration-200 hover:text-lux-blue-light hover:bg-lux-blue/10 focus:outline-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
            </button>
          </div>
          <form x-on:submit.prevent="submitForm">
            <div class="mb-5 pb-5 border-b border-white/[0.06] space-y-5">
              <div>
                <label class="block mb-3 text-sm font-semibold uppercase tracking-wider text-t-primary/70">
                  Categories
                </label>
                <div class="space-y-1">
                  <a
                    href="{{ '/products' | shopUrl }}"
                    class="text-sm text-t-primary/70 py-2.5 px-4 block w-full rounded-lux-sm border border-transparent transition-all duration-200 hover:bg-white/[0.04] {% if not category %}bg-lux-blue/10 !border-lux-blue/20 text-lux-blue-light{% endif %}"
                  >
                    All Categories
                  </a>
                  {% for cat in category_links %}
                    <a
                      href="{{ cat.url }}"
                      class="text-sm text-t-primary/70 py-2.5 px-4 block w-full rounded-lux-sm border border-transparent transition-all duration-200 hover:bg-white/[0.04] {% if category and category.id == cat.id %}bg-lux-blue/10 !border-lux-blue/20 text-lux-blue-light{% endif %}"
                      style="padding-left: {{ (cat.depth * 12 + 16) }}px"
                    >
                      {{ cat.name }}
                    </a>
                  {% endfor %}
                </div>
              </div>
              <div>
                <label for="filters[keyword]" class="block mb-3 text-sm font-semibold uppercase tracking-wider text-t-primary/70">
                  Keyword
                </label>
                <input
                  type="text"
                  name="filters[keyword]"
                  id="filters[keyword]"
                  value="{{ filters.keyword }}"
                  placeholder="Search..."
                  class="lux-input"
                />
              </div>
              <div>
                <label class="block mb-3 text-sm font-semibold uppercase tracking-wider text-t-primary/70">
                  Price Range
                </label>
                <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="lux-input pr-10"
                    />
                    <span class="absolute top-1/2 right-3 -translate-y-1/2 text-t-primary/40 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="lux-input pr-10"
                    />
                    <span class="absolute top-1/2 right-3 -translate-y-1/2 text-t-primary/40 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div class="space-y-3">
              <button type="submit" class="btn-primary w-full">
                <span>Apply Filters</span>
                <i class="fa fa-arrow-right"></i>
              </button>
              <a
                href="{{ '/products' | shopUrl }}"
                class="btn-outline w-full"
              >
                <span>Reset</span>
                <i class="fa fa-rotate-left"></i>
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  {% for item in items %}
    {% if item.type == 'group' %}
      <div
        x-cloak
        x-show="openGroupModalId == '{{ item.id }}'"
        class="fixed inset-0 z-50 overflow-y-auto"
      >
        <div class="flex items-center justify-center min-h-screen p-4 text-center">
          <div
            x-cloak
            @click="closeGroupModal"
            x-show="openGroupModalId == '{{ item.id }}'"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200 transform"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 lux-modal-backdrop"
          ></div>
          <div 
            x-cloak
            x-show="openGroupModalId == '{{ item.id }}'"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
            x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
            x-transition:leave="transition ease-in duration-200 transform"
            x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
            x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
            class="inline-block w-full max-w-[76rem] glass rounded-lux-lg transform"
          >
            <div class="overflow-hidden text-t-primary text-left p-5 md:p-6">
              <div class="flex items-start justify-between gap-4 mb-6 sm:mb-8">
                <h3 class="text-xl font-bold truncate tracking-tight">
                  {{ item.name }}
                </h3>
                <button @click="closeGroupModal" class="flex items-center justify-center size-9 rounded-lg text-t-primary/60 bg-white/[0.03] border border-white/[0.06] transition-all duration-200 hover:text-lux-blue-light hover:bg-lux-blue/10 focus:outline-none">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
                {% for product in item.products %}
                  {% render_snippet "product-card.njk", product=product %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</section>
