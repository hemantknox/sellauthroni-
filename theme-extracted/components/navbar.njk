<nav
  class="component lux-navbar"
  data-component-id="navbar"
  x-data="{
    isCollapsed: true,
    menuHeight: 0,
    scrolled: false
  }"
  x-init="window.addEventListener('scroll', () => scrolled = window.scrollY > 20)"
  :class="{ 'scrolled': scrolled }"
>
  <div class="flex items-center justify-between flex-wrap w-full">
    <div class="flex items-center p-4 lg:p-5">
      {% if global.components.navbar.show_logo or global.components.navbar.show_shop_name %}
        <a href="{{ '/' | shopUrl }}" class="flex items-center justify-center gap-3 lg:justify-start group">
          {% if global.components.navbar.show_logo and shop.image_url %}
            <img
              src="{{ shop.image_url }}"
              alt="{{ shop.name }}"
              class="max-h-9 rounded-lg transition-transform duration-300 group-hover:scale-105"
            />
          {% endif %}
          {% if global.components.navbar.show_shop_name %}
            <h1 class="text-t-primary text-lg lg:text-xl font-bold tracking-tight">{{ shop.name }}</h1>
          {% endif %}
        </a>
      {% endif %}
    </div>

    <div class="flex items-center gap-2 mr-3 lg:mr-5">
      {% if not global.components.navbar.hide_currency_selector %}
        {% if currency_rates_usd | length > 1 %}
          <div class="currency-selector xs lg:hidden">
            <select class="bg-transparent text-transparent font-semibold" style="width: 78px; height: 40px;">
              {% for code, rate in currency_rates_usd %}
                <option value="{{ code }}">
                  <span class="flex items-center justify-between">
                    <span>
                      <span class="inline-block w-10 bg-white/5 text-t-primary text-center px-1 py-px mr-1 symbol">{{ currency_symbols[code] }}</span>
                      <span class="text-t-primary code">{{ code.toUpperCase() }}</span>
                    </span>
                    {% if code.toUpperCase() == currency %}
                      <span class="text-t-primary/75 text-xs default">Default</span>
                    {% endif %}
                  </span>
                </option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
      {% endif %}

      {% if not global.components.navbar.hide_cart %}
        <a href="{{ '/cart' | shopUrl }}" class="inline-flex items-center justify-center size-10 relative bg-white/[0.03] border border-white/[0.08] text-t-primary/75 text-base transition-all ease-out duration-200 rounded-lg lg:hidden hover:bg-lux-blue/10 hover:text-lux-blue-light hover:border-lux-blue/30 focus:outline-none">
          <i class="fa fa-cart-shopping"></i>
          <template x-if="appCart.countWithQuantities > 0">
            <span class="absolute -top-1.5 -right-1.5 inline-flex items-center justify-center min-w-[1.125rem] h-[1.125rem] px-1 bg-gradient-to-br from-lux-blue to-lux-purple text-white text-[0.625rem] font-bold rounded-full shadow-md">
              <span x-text="appCart.countWithQuantities > 9 ? '9+' : appCart.countWithQuantities"></span>
            </span>
          </template>
        </a>
      {% endif %}

      <button
        type="button" 
        x-on:click="isCollapsed = !isCollapsed; $nextTick(() => menuHeight = isCollapsed ? 0 : $refs.menu.scrollHeight)" 
        class="inline-flex items-center justify-center size-10 bg-white/[0.03] border border-white/[0.08] text-t-primary/75 text-sm transition-all ease-out duration-200 rounded-lg lg:hidden hover:bg-lux-blue/10 hover:text-lux-blue-light hover:border-lux-blue/30 focus:outline-none"
        aria-label="Toggle menu"
      >
        <svg class="size-4 transition-transform duration-300" :class="{ 'rotate-90': !isCollapsed }" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>
    </div>

    <div
      x-ref="menu" 
      class="w-full overflow-hidden lg:overflow-visible transition-all duration-300 ease-out lg:w-auto lg:!h-auto"
      x-bind:style="{ height: isCollapsed ? '0px' : menuHeight + 'px' }"
      x-cloak
    >
      <div class="flex flex-col gap-1 p-3 lg:flex-row lg:justify-end lg:items-center lg:gap-1 lg:p-5">
        {% for link in global.components.navbar.links %}
        {% set lActive = false %}
        {% if (link.link == '/' and templateName == 'shop') or (link.link == '/cart' and templateName == 'cart') or (link.link == '/products' and templateName == 'products') or (link.link == '/terms-of-service' and templateName == 'terms') or (link.link == '/privacy-policy' and templateName == 'privacy-policy') or (link.link == '/refund-policy' and templateName == 'refund-policy') or (link.link == '/feedback' and templateName == 'feedback') or (link.link == '/status' and templateName == 'status') or (link.link == '/faq' and templateName == 'faq') or (link.link == '/blog' and templateName == 'blog') %}
        {% set lActive = true %}
        {% endif %}

        {% if lActive and link.shape == 'regular' %}
        {% set lClass = 'text-t-primary' %}
        {% elif not lActive and link.shape == 'regular' %}
        {% set lClass = 'text-t-primary/70 hover:text-t-primary' %}
        {% elif lActive and link.shape == 'button' %}
        {% set lClass = 'text-white bg-gradient-to-r from-lux-blue to-lux-purple border-none shadow-md' %}
        {% elif not lActive and link.shape == 'button' %}
        {% set lClass = 'text-lux-blue-light bg-lux-blue/10 border border-lux-blue/30 hover:bg-lux-blue/20' %}
        {% endif %}

        <a
          href="{{ link.link | shopUrl }}"
          target="{{ '_blank' if link.new_tab }}"
          class="relative px-4 py-2 whitespace-nowrap text-sm font-medium rounded-lg transition-all duration-200 {{ lClass }}"
        >
          {% if lActive and link.shape == 'regular' %}
            <span class="absolute inset-x-3 -bottom-px h-0.5 bg-gradient-to-r from-lux-blue to-lux-purple rounded-full"></span>
          {% endif %}
          {{ link.text }}
        </a>
        {% endfor %}

        {% if not global.components.navbar.hide_customer_dashboard %}
          {% if shop_customer %}
            <a
              href="{{ '/customer/dashboard' | shopUrl }}"
              class="px-4 py-2 whitespace-nowrap text-sm font-medium text-left text-t-primary/70 hover:text-t-primary rounded-lg transition-all duration-200 flex items-center gap-2"
            >
              <i class="fa fa-user-circle text-lux-blue-light"></i>
              My Account
            </a>
          {% else %}
            <button
              type="button"
              @click="appCustomer.loginOrRedirect()"
              class="px-4 py-2 whitespace-nowrap text-sm font-medium text-left text-t-primary/70 hover:text-t-primary rounded-lg transition-all duration-200 flex items-center gap-2"
            >
              <i class="fa fa-sign-in-alt text-lux-blue-light"></i>
              Login
            </button>
          {% endif %}
        {% endif %}

        {% if not global.components.navbar.hide_currency_selector %}
          {% if currency_rates_usd | length > 1 %}
            <div class="currency-selector lg hidden lg:block">
              <select class="bg-transparent border border-white/[0.08] text-transparent font-semibold rounded-lg" style="width: 80px; height: 40px;">
                {% for code, rate in currency_rates_usd %}
                  <option value="{{ code }}">
                    <span class="flex items-center justify-between">
                      <span>
                        <span class="inline-block w-10 bg-white/5 text-t-primary text-center px-1 py-px mr-1 symbol">{{ currency_symbols[code] }}</span>
                        <span class="text-t-primary code">{{ code.toUpperCase() }}</span>
                      </span>
                      {% if code.toUpperCase() == currency %}
                        <span class="text-t-primary/75 text-xs default">Default</span>
                      {% endif %}
                    </span>
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}
        {% endif %}

        {% if not global.components.navbar.hide_cart %}
          <a href="{{ '/cart' | shopUrl }}" class="hidden lg:inline-flex items-center justify-center gap-2 px-4 py-2.5 relative text-sm text-white font-semibold bg-gradient-to-r from-lux-blue to-lux-purple rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-lux-blue/30 hover:-translate-y-0.5">
            <i class="fa fa-cart-shopping"></i>
            <span>Cart</span>
            <template x-if="appCart.countWithQuantities > 0">
              <span class="absolute -top-1.5 -right-1.5 inline-flex items-center justify-center min-w-[1.125rem] h-[1.125rem] px-1 bg-white text-lux-blue text-[0.625rem] font-bold rounded-full shadow-md">
                <span x-text="appCart.countWithQuantities > 9 ? '9+' : appCart.countWithQuantities"></span>
              </span>
            </template>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</nav>
