<section class="component" data-component-id="{{ componentId }}">
  <div x-data="cartPage">
    <div class="py-6 lg:py-8">
      <div class="flex items-center justify-center mb-4 md:mb-6 lg:mb-8">
        <div class="inline-block">
          <h1 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl tracking-tight lux-heading">
            Shopping Cart
          </h1>
        </div>
      </div>

      <div>
        <div class="flex flex-col gap-4 mb-16 lg:flex-row lg:gap-8 lg:mb-32">
          <div class="lg:w-3/4">
            <div
              x-cloak
              x-show="fullCartShowMessages"
              class="transition-opacity"
              x-transition:enter="transition ease-out duration-300 transform"
              x-transition:enter-start="opacity-0" 
              x-transition:enter-end="opacity-100"
              x-transition:leave="transition ease-in duration-200 transform"
              x-transition:leave-start="opacity-100" 
              x-transition:leave-end="opacity-0"
            >
              <div class="bg-lux-blue/10 border border-lux-blue/30 text-lux-blue-light p-4 mb-4 rounded-lux-sm">
                <template x-for="(message, index) in fullCartMessages" :key="index">
                  <p x-text="message"></p>
                </template>
              </div>
            </div>

            <div>
              <div x-show="fullCartLoading" class="p-4 border border-white/[0.06] bg-card/50 text-t-primary text-center rounded-lux-sm">
                <i class="fa fa-circle-notch animate-spin text-lux-blue-light text-xl md:text-2xl lg:text-3xl"></i>
              </div>

              <template x-if="!fullCartLoading">
                <div>
                  <template x-if="fullCart.length === 0">
                    <div class="p-8 border border-white/[0.06] bg-card/50 text-t-primary rounded-lux-sm text-center">
                      <i class="fa fa-cart-shopping text-5xl text-t-primary/20 mb-4"></i>
                      <p class="text-t-primary/60 text-base">Your cart is empty.</p>
                      <a href="{{ '/products' | shopUrl }}" class="btn-primary mt-6">
                        <span>Browse Products</span>
                        <i class="fa fa-arrow-right"></i>
                      </a>
                    </div>
                  </template>

                  <template x-if="fullCart.length > 0">
                    <div class="flex flex-col gap-3 md:gap-4 lg:gap-5">
                      <template x-for="(cartItem, index) in fullCart" :key="index">
                        <div class="flex flex-col p-1 sm:flex-row sm:justify-between sm:p-0 border border-white/[0.06] bg-card/50 text-t-primary rounded-lux-sm overflow-hidden">
                          <div class="flex-1 flex gap-2 truncate sm:gap-3 md:gap-4">
                            <div class="flex justify-center items-center w-full max-w-24 relative pl-1 py-1 sm:max-w-36 sm:pl-3 sm:py-3 aspect-product-card-image">
                              <template x-if="cartItem.product.image_url">
                                <img :src="cartItem.product.image_url" class="w-full aspect-product-card-image object-product-image" loading="lazy" />
                              </template>
                              <template x-if="!cartItem.product.image_url">
                                <div class="flex justify-center items-center text-accent-400 aspect-product-card-image">
                                  <svg xmlns="http://www.w3.org/2000/svg" class="size-16" viewBox="0 0 256 256">
                                    <path
                                      fill="currentColor"
                                      d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"
                                    />
                                  </svg>
                                </div>
                              </template>
                            </div>

                            <div class="flex-1 text-left pr-2 py-1 truncate sm:pr-3 sm:py-3">
                              <div class="flex justify-between items-center gap-2 truncate">
                                <a :href="'{{ '/product/' | shopUrl }}' + cartItem.product.path" class="text-t-primary text-base font-bold truncate sm:text-lg hover:underline">
                                  <span x-text="cartItem.product.name"></span>
                                </a>
                                <button
                                  type="button"
                                  @click="removeItem(index)"
                                  class="text-t-primary focus:outline-none hover:text-lux-blue-light sm:hidden"
                                >
                                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4 sm:size-5" fill="currentColor" viewBox="0 0 256 256"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path></svg>
                                </button>
                              </div>
                              <p class="text-t-primary/75 text-sm truncate sm:text-base" x-text="cartItem.variant.name"></p>
                              <template x-if="getAvailableVolumeDiscount(index)">
                                <div class="text-t-primary/50 text-xs truncate mt-px sm:mt-0.5">
                                  Buy <span x-text="getAvailableVolumeDiscount(index)?.quantity - cartItem.quantity"></span> more to get a <span x-text="getAvailableVolumeDiscount(index)?.percentage"></span>% discount.
                                </div>
                              </template>
                              <template x-for="deal in getDealsForItem(index)" :key="deal.id">
                                <div>
                                  <div x-show="cartItem.quantity < deal.buy_quantity + deal.discounted_quantity" class="text-t-primary/50 text-xs truncate mt-px sm:mt-0.5">
                                    Buy <span x-text="deal.buy_quantity + deal.discounted_quantity - cartItem.quantity"></span> more —
                                    <span x-text="deal.percentage == 100 ? 'get ' + deal.discounted_quantity + ' free' : 'get ' + deal.discounted_quantity + ' at -' + deal.percentage + '%'"></span>
                                    (<span x-text="deal.name"></span>)
                                  </div>
                                  <div x-show="cartItem.quantity >= deal.buy_quantity + deal.discounted_quantity" class="flex items-center gap-1 text-xs text-lux-blue-light mt-px sm:mt-0.5">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="size-3" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                                    <span x-text="deal.name"></span>
                                  </div>
                                </div>
                              </template>
                              <template x-if="cartItem.addons && cartItem.addons.length > 0">
                                <div class="flex items-center gap-1 mt-0.5 sm:mt-1">
                                  <template x-for="(addon, addonIndex) in cartItem.addons" :key="addonIndex">
                                    <div class="inline-block py-0.5 px-2 bg-white/[0.03] border border-white/[0.06] text-t-primary/50 text-xs rounded-lux-sm">
                                      <span x-text="addon.product.name"></span>
                                    </div>
                                  </template>
                                </div>
                              </template>
                            </div>
                          </div>
                          <div class="flex items-center justify-between pl-1 pr-4 pt-2 pb-1.5 mt-2 border-t border-t-white/[0.06] sm:border-t-0 sm:justify-end sm:pl-0 sm:py-0 sm:mt-0 md:gap-6 lg:gap-8 lg:pr-8">
                            <div class="max-w-32 flex overflow-hidden rounded-lux-sm focus-within:border-lux-blue/40 focus-within:ring-2 focus-within:ring-lux-blue/20 border border-white/[0.06]">
                              <button
                                type="button"
                                @click="changeQuantity(index, cartItem.quantity - 1)"
                                :disabled="cartItem.quantity <= getMinQuantity(index)"
                                class="bg-white/5 hover:bg-lux-blue/20 hover:text-lux-blue-light size-8 flex justify-center items-center transition-colors duration-200 ease-out disabled:pointer-events-none disabled:opacity-50"
                              >
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  fill="none"
                                  viewBox="0 0 24 24"
                                  stroke-width="1.5"
                                  stroke="currentColor"
                                  class="size-4"
                                >
                                  <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M19.5 12h-15"
                                  />
                                </svg>
                              </button>
                              <input
                                type="number"
                                x-model.number="cartItem.quantity"
                                class="w-[calc(100%-64px)] bg-white/[0.025] text-center text-t-primary text-sm focus:outline-none py-1.5 px-3 disabled:opacity-50"
                              />
                              <button
                                type="button"
                                @click="changeQuantity(index, cartItem.quantity + 1)"
                                :disabled="cartItem.quantity >= getMaxQuantity(index)"
                                class="bg-white/5 hover:bg-lux-blue/20 hover:text-lux-blue-light size-8 flex justify-center items-center transition-colors duration-200 ease-out disabled:pointer-events-none disabled:opacity-50"
                              >
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  fill="none"
                                  viewBox="0 0 24 24"
                                  stroke-width="1.5"
                                  stroke="currentColor"
                                  class="size-4"
                                >
                                  <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M12 4.5v15m7.5-7.5h-15"
                                  />
                                </svg>
                              </button>
                            </div>
                            <div>
                              <p class="text-base text-t-primary text-center font-medium sm:min-w-20 sm:text-lg">
                                <span x-text="appCurrency.format(getItemSinglePrice(index), cartItem.product.currency)"></span>
                              </p>
                            </div>
                            <button
                              type="button"
                              @click="removeItem(index)"
                              class="hidden text-t-primary focus:outline-none hover:text-lux-error sm:block"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 sm:size-5" fill="currentColor" viewBox="0 0 256 256"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path></svg>
                            </button>
                          </div>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </div>
          <div class="lg:w-1/4">
            <div class="flex flex-col gap-4">
            <div class="flex flex-col justify-between gap-4 glass rounded-lux-lg p-4 md:p-5 lg:p-6 text-t-primary">
              <form @submit.prevent="checkout">
                <div class="mb-4 pb-2 border-b border-white/[0.06]">
                  <label class="block mb-2 text-sm font-semibold uppercase tracking-wider text-t-primary/70">Your Order</label>
                  <div>
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-sm text-t-primary/50">Subtotal</span>
                      <span class="text-sm text-t-primary/75">
                        <span x-text="appCurrency.format(cartSubtotalPrice, cartCurrency)"></span>
                      </span>
                    </div>
                    <template x-for="deal in quantityDeals" :key="'qd-' + deal.id">
                      <div x-show="getQuantityDealDiscount(deal) > 0" class="flex items-center justify-between mb-1">
                        <span class="text-sm text-t-primary/50" x-text="deal.name"></span>
                        <span class="text-sm text-lux-blue-light">-<span x-text="appCurrency.format(getQuantityDealDiscount(deal), cartCurrency)"></span></span>
                      </div>
                    </template>
                    <template x-for="offer in bundleOffers" :key="'bo-' + offer.id">
                      <div x-show="getBundleDiscount(offer) > 0" class="flex items-center justify-between mb-1">
                        <span class="text-sm text-t-primary/50" x-text="offer.name"></span>
                        <span class="text-sm text-lux-blue-light">-<span x-text="appCurrency.format(getBundleDiscount(offer), cartCurrency)"></span></span>
                      </div>
                    </template>
                    <div x-show="cartTotalPrice < cartSubtotalPrice" class="flex items-center justify-between mb-1 pt-1 border-t border-white/[0.06]">
                      <span class="text-sm font-semibold text-t-primary">Total</span>
                      <span class="text-sm font-semibold text-t-primary">
                        <span x-text="appCurrency.format(cartTotalPrice, cartCurrency)"></span>
                      </span>
                    </div>
                  </div>
                </div>
                
                {% if altcha %}
                  <div
                    x-cloak
                    x-show="!altchaPayload"
                    class="transition-opacity"
                    x-transition:enter="transition ease-out duration-300 transform"
                    x-transition:enter-start="opacity-0"
                    x-transition:enter-end="opacity-100"
                    x-transition:leave="transition ease-in duration-200 transform"
                    x-transition:leave-start="opacity-100"
                    x-transition:leave-end="opacity-0"
                  >
                    <altcha-widget
                      challengejson='{{ altcha | json }}'
                      auto="onload"
                      hidefooter="true"
                      hidelogo="true"
                      x-ref="altcha"
                    ></altcha-widget>
                  </div>
                {% endif %}

                <div
                  x-cloak
                  x-show="submitError"
                  class="transition-opacity"
                  x-transition:enter="transition ease-out duration-300 transform"
                  x-transition:enter-start="opacity-0" 
                  x-transition:enter-end="opacity-100"
                  x-transition:leave="transition ease-in duration-200 transform"
                  x-transition:leave-start="opacity-100" 
                  x-transition:leave-end="opacity-0"
                >
                  <div class="bg-lux-error/10 border border-lux-error/30 text-lux-error p-4 my-4 rounded-lux-sm">
                    <span x-text="submitError"></span>
                  </div>
                </div>

                <button
                  type="submit"
                  :disabled="fullCartLoading || fullCart.length === 0 || isSubmitting || submitDisabled"
                  class="btn-primary mt-4 w-full text-base"
                >
                  <span>Checkout</span>
                  <template x-if="!isSubmitting">
                    <i class="fa fa-shopping-cart"></i>
                  </template>
                  <template x-if="isSubmitting">
                    <i class="fa fa-circle-notch animate-spin"></i>
                  </template>
                </button>
              </form>
            </div>

            <template x-if="bundleOffers.length > 0">
              <div class="flex flex-col gap-3">
                <template x-for="offer in bundleOffers" :key="offer.id">
                  <div class="flex flex-col gap-3 glass rounded-lux-lg p-4 md:p-5 text-t-primary">
                    <div class="flex items-center justify-between gap-2">
                      <span class="text-sm font-semibold" x-text="offer.name"></span>
                      <div class="flex items-center gap-2 flex-shrink-0">
                        <span class="lux-badge"
                          x-text="offer.type === 'percentage' ? '-' + offer.discount + '%' : appCurrency.format(offer.discount, cartCurrency)">
                        </span>
                        <template x-if="offer.ends_at">
                          <span class="text-xs text-t-primary/40" x-text="'Ends ' + new Date(offer.ends_at).toLocaleDateString()"></span>
                        </template>
                      </div>
                    </div>
                    <ul class="flex flex-col gap-2">
                      <template x-for="item in offer.items" :key="item.id">
                        <li class="flex items-center gap-3">
                          <template x-if="item.image_url">
                            <img :src="item.image_url" :alt="item.name" class="size-8 object-cover flex-shrink-0">
                          </template>
                          <template x-if="!item.image_url">
                            <div class="size-8 bg-white/5 flex-shrink-0"></div>
                          </template>
                          <span class="flex-1 text-xs font-medium truncate" x-text="item.name + (item.quantity > 1 ? ' ×' + item.quantity : '')"></span>
                          <template x-if="item.in_cart">
                            <span class="flex items-center gap-1 text-xs text-lux-blue-light font-medium flex-shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" class="size-3" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                              In cart
                            </span>
                          </template>
                          <template x-if="!item.in_cart">
                            <a
                              :href="item.path ? '{{ '/product/' | shopUrl }}' + item.path : '#'"
                              class="text-xs font-medium text-lux-blue-light border border-lux-blue/30 px-1.5 py-0.5 flex-shrink-0 hover:bg-lux-blue/10 transition-colors duration-200 ease-out rounded-lux-sm"
                            >Add</a>
                          </template>
                        </li>
                      </template>
                    </ul>
                    <div x-show="isBundleComplete(offer.id)" class="flex items-center justify-center gap-2 text-sm text-lux-blue-light py-1">
                      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                      Bundle discount applied
                    </div>
                  </div>
                </template>
              </div>
            </template>

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('cartPage', () => ({
      fullCart: [],
      quantityDeals: [],
      bundleOffers: [],
      fullCartLoading: false,
      fullCartMessages: [],
      fullCartShowMessages: false,
      isSubmitting: false,
      submitError: null,
      submitDisabled: false,
      altchaPayload: null,

      init: function () {
        if (this.appCart.items.length > 0) {
          this.fetchFullCart();
        }

        {% if altcha %}
          this.addAltchaEventListener();
        {% endif %}

        window.addEventListener('pageshow', (event) => {
          if (event.persisted) {
            this.isSubmitting = false;
          }
        });
      },

      fetchFullCart: async function () {
        this.fullCartLoading = true;
        this.fullCartMessages = [];
        this.fullCartShowMessages = false;

        const url = new URL('{{ '/v1/cart' | apiInternalUrl }}');
        url.searchParams.append('shopId', '{{ shop.id }}');
        url.searchParams.append('cart', JSON.stringify(this.appCart.items));

        try {
          const response = await fetch(url, {
            method: 'GET',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
            },
          });

          const responseData = await response.json();

          if (responseData?.messages && responseData.messages.length > 0) {
            this.fullCartMessages = responseData.messages;
            this.fullCartShowMessages = true;
            setTimeout(() => {
              this.fullCartShowMessages = false;
            }, 5000);
          }

          // Update full cart state (this one contains product names, images, etc.)
          this.fullCart = responseData.fullCart;

          this.quantityDeals = responseData.quantity_deals || [];
          this.bundleOffers = responseData.bundle_offers || [];

          // Update global cart state
          this.appCart.set(responseData.cart);
        } catch (error) {
          console.error(error);
        } finally {
          this.fullCartLoading = false;
        }
      },

      getDealsForItem: function (index) {
        const item = this.fullCart[index];
        return this.quantityDeals.filter(d => d.variant_id !== null && d.variant_id === item.variantId);
      },

      getQuantityDealDiscount: function (deal) {
        const bundleSize = deal.buy_quantity + deal.discounted_quantity;
        let totalQty;
        if (deal.variant_id !== null) {
          const item = this.fullCart.find(i => i.variantId === deal.variant_id);
          totalQty = item ? item.quantity : 0;
        } else {
          totalQty = this.fullCart.reduce((s, i) => s + i.quantity, 0);
        }
        let applications = Math.floor(totalQty / bundleSize);
        if (deal.max_uses_per_cart) applications = Math.min(applications, deal.max_uses_per_cart);
        if (applications === 0) return 0;

        let unitPrice;
        if (deal.variant_id !== null) {
          const idx = this.fullCart.findIndex(i => i.variantId === deal.variant_id);
          unitPrice = idx >= 0 ? this.getItemSinglePrice(idx) : 0;
        } else {
          const prices = this.fullCart.map((_, idx) => this.getItemSinglePrice(idx)).sort((a, b) => a - b);
          unitPrice = prices[0] || 0;
        }
        return applications * deal.discounted_quantity * unitPrice * (deal.percentage / 100);
      },

      getBundleDiscount: function (offer) {
        if (!offer.active || offer.applications === 0) return 0;
        if (offer.type === 'percentage') {
          let bundleItemsTotal = 0;
          for (const item of offer.items) {
            const cartItem = item.type === 'variant'
              ? this.fullCart.find(i => i.variantId === item.id)
              : this.fullCart.find(i => i.productId === item.id);
            if (cartItem) {
              bundleItemsTotal += this.getItemSinglePrice(this.fullCart.indexOf(cartItem)) * (item.quantity || 1);
            }
          }
          return offer.applications * bundleItemsTotal * (offer.discount / 100);
        }
        return offer.applications * offer.discount;
      },

      isBundleComplete: function (offerId) {
        const offer = this.bundleOffers.find(o => o.id === offerId);
        if (!offer) return false;
        return offer.items.every(item => {
          const required = item.quantity || 1;
          const entry = item.type === 'variant'
            ? this.fullCart.find(i => i.variantId === item.id)
            : this.fullCart.find(i => i.productId === item.id);
          return entry && entry.quantity >= required;
        });
      },

      getAvailableVolumeDiscount: function (index) {
        const item = this.fullCart[index];

        if (item.variant.volume_discounts) {
          const volumeDiscounts = item.variant.volume_discounts.sort((a, b) => a.quantity - b.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (item.quantity < parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      getAppliedVolumeDiscount: function (index) {
        const item = this.fullCart[index];

        if (item.variant.volume_discounts) {
          const volumeDiscounts = item.variant.volume_discounts.sort((a, b) => b.quantity - a.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (item.quantity >= parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      getMinQuantity: function (index) {
        const item = this.fullCart[index];
        
        const min = item.variant.quantity_min || 1;

        if (item.variant.stock === 0) {
          return 0;
        }

        return min;
      },

      getMaxQuantity: function (index) {
        const item = this.fullCart[index];
        
        const max = item.variant.quantity_max || 10000;

        if (item.variant.stock === 0) {
          return 0;
        }

        if (item.product.hide_stock_count) {
          return max;
        }

        if (item.variant.stock === -1) {
          return max;
        }

        return Math.min(max, item.variant.stock);
      },

      changeQuantity: function (index, quantity) {
        const min = this.getMinQuantity(index);
        const max = this.getMaxQuantity(index);
        const newQuantity = Math.min(Math.max(min, quantity), max);

        const item = this.fullCart[index];

        this.fullCart[index].quantity = newQuantity;
        this.appCart.editQuantity(item.variantId, newQuantity);
      },

      removeItem: function (index) {
        const item = this.fullCart[index];

        this.fullCart.splice(index, 1);

        this.appCart.remove(item.variant.id);
      },

      getItemSinglePrice: function (index) {
        const item = this.fullCart[index];

        const volumeDiscount = this.getAppliedVolumeDiscount(index);

        if (volumeDiscount) {
          return item.variant.price * (1 - volumeDiscount.percentage / 100);
        }

        return item.variant.price;
      },

      get cartCurrency() {
        return this.fullCart.length > 0 ? this.fullCart[0].product.currency : 'USD';
      },

      get cartSubtotalPrice() {
        return this.fullCart.reduce((acc, item) => {
          const itemSinglePrice = this.getItemSinglePrice(this.fullCart.indexOf(item));
          const itemAddonsPrice = item.addons ? item.addons.reduce((sum, addon) => sum + addon.variant.price, 0) : 0;
          return acc + (item.quantity * itemSinglePrice) + itemAddonsPrice;
        }, 0);
      },

      get cartTotalPrice() {
        const dealDiscount = this.quantityDeals.reduce((s, d) => s + this.getQuantityDealDiscount(d), 0);
        const bundleDiscount = this.bundleOffers.reduce((s, o) => s + this.getBundleDiscount(o), 0);
        return Math.max(0, this.cartSubtotalPrice - dealDiscount - bundleDiscount);
      },

      addAltchaEventListener: function () {
        this.$refs.altcha.addEventListener('statechange', (event) => {
          if (event.detail.state === 'verifying') {
            this.submitDisabled = true;
          } else if (event.detail.state === 'verified') {
            this.submitDisabled = false;
            this.altchaPayload = event.detail.payload;
          }
        });
      },

      generateRecaptchaToken: async function () {
        return new Promise((resolve) => {
          grecaptcha.ready(
            () =>
              void (async () => {
                const token = await grecaptcha.execute(
                  '{{ shop.recaptcha_key }}',
                  { action: 'checkout_s{{ shop.id }}' },
                );

                resolve(token);
              })(),
          );
        });
      },

      checkout: async function () {
        if (this.isSubmitting) {
          return;
        }

        const formData = {
          cart: this.appCart.items,
          currency: this.appCurrency.currency,
          shopId: '{{ shop.id }}',
        };

        if (window.shopCustomer?.email) {
          formData.email = window.shopCustomer.email;
        }

        {% if altcha %}
          if (this.altchaPayload) {
            formData.altcha = this.altchaPayload;
          }
        {% elif shop.recaptcha_key %}
          try {
            formData.recaptchaToken = await this.generateRecaptchaToken();
          } catch (error) {
            this.submitError = 'reCAPTCHA cannot be loaded. Please refresh the page and turn off any ad blockers.';
            this.isSubmitting = false;
            return;
          }
        {% endif %}

        try {
          this.isSubmitting = true;

          const response = await fetch('{{ '/v1/checkout' | apiInternalUrl }}', {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          });

          const responseData = await response.json();

          if (responseData.url) {
            localStorage.setItem('cart', JSON.stringify([]));
            window.location.href = responseData.url;
          } else {
            this.isSubmitting = false;
            this.submitError = responseData?.message || 'Error in the AJAX request.';

            if (responseData?.error == 'captcha_verification_failed') {
              setTimeout(() => window.location.reload(), 1000);
            }
          }
        } catch (error) {
          console.error(error);
          this.isSubmitting = false;
          this.submitError = 'Unexpected error. Please refresh the page and try again.';
        }
      }
    }));
  });
</script>