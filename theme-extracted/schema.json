{
    "global": {
        "properties": {
            "accent_color": {
                "label": "Accent Color",
                "type": "color"
            },
            "background_color": {
                "label": "Background Color",
                "type": "color"
            },
            "card_color": {
                "label": "Card Background Color",
                "type": "color"
            },
            "text_primary_color": {
                "label": "Primary Text Color",
                "type": "color",
                "default": "#ffffff"
            },
            "text_accent_color": {
                "label": "Accent Text Color",
                "type": "color",
                "default": "#ffffff"
            },
            "font": {
                "label": "Font",
