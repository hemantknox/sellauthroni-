    "components": {
        "announcement": {
            "label": "Announcement",
            "global": true,
            "order": 0,
            "properties": {
                "announcements": {
                    "label": "Announcements",
                    "type": "list",
                    "maxItems": 10,
                    "properties": {
                        "text": {
                            "label": "Text",
                            "type": "text",
                            "default": "New Announcement"
                        },
                        "link": {
                            "label": "Link",
                            "type": "text",
                            "default": ""
                        },
                        "new_tab": {
                            "label": "Open in New Tab",
                            "type": "toggle",
                            "default": false
                        }
                    }
                }
            }
        },
        "navbar": {
            "label": "Navbar",
            "global": true,
            "order": 1,
            "properties": {
                "show_shop_name": {
                    "label": "Show Shop Name",
                    "help": "Defined in Shop Settings",
                    "type": "toggle",
                    "default": true
                },
                "show_logo": {
                    "label": "Show Logo",
                    "help": "Defined in Shop Settings",
                    "type": "toggle",
                    "default": true
                },
                "hide_currency_selector": {
                    "label": "Hide Currency Selector",
                    "type": "toggle",
                    "default": false
                },
                "hide_customer_dashboard": {
                    "label": "Hide Login / My Account",
                    "type": "toggle",
                    "default": false
                },
                "hide_cart": {
                    "label": "Hide Cart",
                    "type": "toggle",
                    "default": false
                },
                "links": {
                    "label": "Links",
                    "type": "list",
                    "maxItems": 10,
                    "properties": {
                        "text": {
                            "label": "Text",
                            "type": "text",
                            "default": "New Link"
                        },
                        "link": {
                            "label": "Link",
                            "type": "text",
                            "default": "#"
                        },
                        "new_tab": {
                            "label": "Open in New Tab",
                            "type": "toggle",
                            "default": false
                        }
                    },
                    "default": [
                        {
                            "text": "Home",
                            "link": "\/",
                            "shape": "regular"
                        },
                        {
                            "text": "Products",
                            "link": "\/products",
                            "shape": "regular"
                        },
                        {
                            "text": "Reviews",
                            "link": "\/feedback",
                            "shape": "regular"
                        },
                        {
                            "text": "Status",
                            "link": "\/status",
                            "shape": "regular"
                        },
                        {
                            "text": "Blog",
                            "link": "\/blog",
                            "shape": "regular"
                        }
                    ]
                }
            }
        },
        "hero": {
            "label": "Hero",
            "templates": ["shop"],
            "properties": {
                "title": {
                    "label": "Title",
                    "type": "text",
                    "default": "Welcome to <span class=\"text-accent-500\">{{ shop.name }}</span>!"
                },
                "subtitle": {
                    "label": "Subtitle",
                    "type": "text",
                    "default": "{{ shop.description }}"
                },
                "show_searchbar": {
                    "label": "Show Searchbar",
                    "type": "toggle",
                    "default": true
                },
                "buttons": {
                    "label": "Buttons",
                    "type": "list",
                    "maxItems": 4,
                    "properties": {
                        "text": {
                            "label": "Text",
                            "type": "text",
                            "default": "New Button"
                        },
                        "icon": {
                            "label": "Icon",
                            "type": "icon"
                        },
                        "link": {
                            "label": "Link",
                            "type": "text",
                            "default": "#"
                        },
                        "new_tab": {
                            "label": "Open in New Tab",
                            "type": "toggle",
                            "default": false
                        },
                        "style": {
                            "label": "Style",
                            "type": "select",
                            "options": [
                                "regular",
                                "outline"
                            ],
                            "default": "regular"
                        }
                    },
                    "default": [
                        {
                            "text": "View Products",
                            "icon": "fas fa-cart-shopping",
                            "link": "\/products",
                            "new_tab": false,
                            "style": "outline"
                        }
                    ]
                },
                "alignment": {
                    "label": "Alignment",
                    "type": "select",
                    "options": [
                        "left",
                        "center",
                        "right"
                    ],
                    "default": "center"
                },
                "height": {
                    "label": "Height",
                    "type": "select",
                    "options": [
                        "short",
                        "medium",
                        "tall"
                    ],
                    "default": "medium"
                },
                "text_width": {
                    "label": "Text Width",
                    "type": "select",
                    "options": [
                        "small",
                        "medium",
                        "large",
                        "full"
                    ],
                    "default": "small"
                },
                "side_image": {
                    "label": "Side Image",
                    "type": "image",
                    "maxImages": 1
                }
            }
        },
        "categories": {
            "label": "Categories",
            "multiple": true,
            "properties": {
                "title": {
                    "label": "Title",
