                "default": "Play"
            },
            "snow": {
                "label": "Snow Effect",
                "type": "toggle",
                "default": false
            },
            "snow_color": {
                "label": "Snowflake Color",
                "type": "color",
                "default": "#ffffff"
            },
            "product_card_image_aspect_ratio": {
                "label": "Product Card Image Aspect Ratio",
                "type": "text",
                "default": "16/9",
                "datalist": ["1/1", "4/3", "16/9"]
            },
            "product_page_image_aspect_ratio": {
                "label": "Product Page Image Aspect Ratio",
                "type": "text",
                "default": "16/9",
                "datalist": ["1/1", "4/3", "16/9"]
            },
            "product_image_fit": {
                "label": "Product Image Fit",
                "type": "select",
                "options": [
                    "scale-down",
                    "cover"
                ],
                "default": "cover"
            },
            "group_card_image_aspect_ratio": {
                "label": "Group Card Image Aspect Ratio",
                "type": "text",
                "default": "16/9",
                "datalist": ["1/1", "4/3", "16/9"]
            },
            "group_image_fit": {
                "label": "Group Image Fit",
                "type": "select",
                "options": [
                    "scale-down",
                    "cover"
                ],
                "default": "cover"
            },
            "blog_card_image_aspect_ratio": {
                "label": "Blog Card Image Aspect Ratio",
                "type": "text",
                "default": "16/9",
                "datalist": ["1/1", "4/3", "16/9"]
