<div class="mt-4 md:mt-6">
    <nav role="navigation" aria-label="Pagination Navigation" class="flex items-center justify-between">
        <div class="flex justify-between flex-1 sm:hidden">
            {% if paginator.prev_page_url %}
                <a href="{{ paginator.prev_page_url }}"
                   class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-t-primary/80 bg-white/[0.03] border border-white/[0.06] hover:text-t-primary hover:bg-lux-blue/10 hover:border-lux-blue/20 focus:outline-none transition ease-out duration-200 rounded-lux-sm">
                    « Previous
                </a>
            {% else %}
                <span
                   class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-t-primary/50 bg-white/[0.03] border border-white/[0.06] cursor-default rounded-lux-sm">
                    « Previous
                </span>
            {% endif %}
            {% if paginator.next_page_url %}
                <a href="{{ paginator.next_page_url }}"
                   class="relative inline-flex items-center px-4 py-2 ml-3 text-sm font-medium text-t-primary/80 bg-white/[0.03] border border-white/[0.06] hover:text-t-primary hover:bg-lux-blue/10 hover:border-lux-blue/20 focus:outline-none transition ease-out duration-200 rounded-lux-sm">
                    Next »
                </a>
            {% else %}
                <span
                   class="relative inline-flex items-center px-4 py-2 ml-3 text-sm font-medium text-t-primary/50 bg-white/[0.03] border border-white/[0.06] cursor-default rounded-lux-sm">
                    Next »
                </span>
            {% endif %}
        </div>

        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-t-primary/60">
                    Showing
                    <span class="font-medium text-t-primary/80">{{ paginator.from }}</span>
                    to
                    <span class="font-medium text-t-primary/80">{{ paginator.to }}</span>
                    of
                    <span class="font-medium text-t-primary/80">{{ paginator.total }}</span>
                    results
                </p>
            </div>
            <div>
                <span class="relative z-0 inline-flex rounded-lux-sm overflow-hidden">
                    {% if paginator.prev_page_url %}
                        <a href="{{ paginator.prev_page_url }}"
                           class="relative inline-flex items-center px-3 py-2 text-sm font-medium text-t-primary/80 bg-white/[0.03] border border-white/[0.06] hover:text-lux-blue-light hover:bg-lux-blue/10 focus:z-10 focus:outline-none transition ease-out duration-200"
                           aria-label="« Previous">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                            </svg>
                        </a>
                    {% else %}
                        <span
                           class="relative inline-flex items-center px-3 py-2 text-sm font-medium text-t-primary/50 bg-white/[0.03] opacity-50 border border-white/[0.06] cursor-default">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                            </svg>
                        </span>
                    {% endif %}

                    {% for link in paginator.links %}
                        {% if link.label != '&laquo; Previous' and link.label != 'Next &raquo;' %}
                            {% if link.url %}
                                {% if link.active %}
                                    <span
                                    aria-current="page"
                                    class="relative inline-flex items-center px-4 py-2 -ml-px text-sm font-medium text-white bg-gradient-to-r from-lux-blue to-lux-purple border border-lux-blue/30 cursor-default">
                                        {{ link.label }}
                                    </span>
                                {% else %}
                                    <a href="{{ link.url }}"
                                    class="relative inline-flex items-center px-4 py-2 -ml-px text-sm font-medium text-t-primary/80 bg-white/[0.03] border border-white/[0.06] hover:text-lux-blue-light hover:bg-lux-blue/10 focus:z-10 focus:outline-none transition ease-out duration-200"
                                    aria-label="Go to page {{ link.label }}">
                                        {{ link.label }}
                                    </a>
                                {% endif %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    {% if paginator.next_page_url %}
                        <a href="{{ paginator.next_page_url }}"
                           rel="next"
                           class="relative inline-flex items-center px-3 py-2 -ml-px text-sm font-medium text-t-primary/80 bg-white/[0.03] border border-white/[0.06] hover:text-lux-blue-light hover:bg-lux-blue/10 focus:z-10 focus:outline-none transition ease-out duration-200"
                           aria-label="Next »">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                            </svg>
                        </a>
                    {% else %}
                        <span
                           class="relative inline-flex items-center px-3 py-2 -ml-px text-sm font-medium text-t-primary/50 bg-white/[0.03] opacity-50 border border-white/[0.06] cursor-default">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                            </svg>
                        </span>
                    {% endif %}
                </span>
            </div>
        </div>
    </nav>
</div>
