<a
  class="block h-full lux-card group overflow-hidden"
  href="{{ 'javascript:void(0);' if product.type == 'group' else ( ('/product/' + product.path) | shopUrl ) }}"
  @click="{{ 'openGroupModal(' ~ product.id ~ ')' if product.type == 'group' else '' }}"
>
  <div class="h-full flex flex-col">
    <div class="text-center px-4 py-3 border-b border-white/[0.06]">
      <h3 class="text-base font-semibold truncate md:text-lg">
        {{ product.name }}
      </h3>
      {% if product.product_badges.card|length > 0 %}
        <div class="badges flex items-center justify-center gap-2 flex-wrap mt-2">
          {% for productBadge in product.product_badges.card %}
            <div class="lux-badge" style="background-color: {{ productBadge.color }}" data-text="{{ productBadge.label }}" data-color="{{ productBadge.color }}">
              {% if productBadge.icon %}
                <i class="{{ productBadge.icon }} fa-fw"></i>
              {% endif %}
              {{ productBadge.label }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="relative overflow-hidden p-3 flex-1">
      {% if product.image_urls|length > 0 %}
      <img src="{{ product.image_urls[0] }}" class="w-full rounded-lux-md {{ 'aspect-group-card-image object-group-image' if product.type == 'group' else 'aspect-product-card-image object-product-image' }} transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      {% elif product.image_url %}
      <img src="{{ product.image_url }}" class="w-full rounded-lux-md {{ 'aspect-group-card-image object-group-image' if product.type == 'group' else 'aspect-product-card-image object-product-image' }} transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      {% else %}
      <div class="flex justify-center items-center text-lux-blue/30 rounded-lux-md {{ 'aspect-group-card-image' if product.type == 'group' else 'aspect-product-card-image' }} bg-gradient-to-br from-lux-blue/5 to-lux-purple/5">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-24" viewBox="0 0 256 256">
          <path
            fill="currentColor"
            d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"
          />
        </svg>
      </div>
      {% endif %}
    </div>
    <div class="text-left px-4 pb-4">
      <div class="flex items-center justify-between gap-2 truncate mb-4">
        <p class="text-base font-semibold text-t-primary/60 truncate">
          <span class="bg-gradient-to-r from-lux-blue-light to-lux-purple-light bg-clip-text text-transparent">
            {% if product.min_price != product.max_price %}
              <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price, product.currency) }}
              </span>
              -
              <span x-text="appCurrency.format({{ product.max_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.max_price, product.currency) }}
              </span>
            {% elif product.min_price %}
              <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price, product.currency) }}
              </span>
            {% else %}
              -
            {% endif %}
          </span>

          {% if product.min_price_slash and product.max_price_slash and product.min_price_slash != product.max_price_slash %}
            <span class="text-sm line-through">
              <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price_slash, product.currency) }}
              </span>
              -
              <span x-text="appCurrency.format({{ product.max_price_slash }}, '{{ product.currency }}')">
                {{ formatPrice(product.max_price_slash, product.currency) }}
              </span>
            </span>
          {% elif product.min_price_slash %}
            <span class="text-sm line-through">
              <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price_slash, product.currency) }}
              </span>
            </span>
          {% endif %}
        </p>
        <p class="text-sm text-t-primary/50 whitespace-nowrap">
          {% if product.type == 'group' %}
            {{ product.products | length }} Products
          {% else %}
            {% if product.stock === 0 %}
              <span class="text-lux-error">Out of Stock</span>
            {% elif product.hide_stock_count %}
              <span class="text-lux-success">In Stock</span>
            {% elif product.stock === -1 %}
              <span class="inline-flex items-center gap-1 text-lux-success">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
                In Stock
              </span>
            {% else %}
              <span class="text-lux-success">{{ product.stock }} In Stock</span>
            {% endif %}
          {% endif %}
        </p>
      </div>
      <div class="flex items-center justify-center gap-2 text-white text-center font-semibold px-4 py-2.5 rounded-lux-sm bg-gradient-to-r from-lux-blue to-lux-purple transition-all duration-200 group-hover:shadow-lg group-hover:shadow-lux-blue/30">
        View Details
        <svg class="size-4 transition-transform duration-200 group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><path fill="currentColor" d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10z"/></svg>
      </div>
    </div>
  </div>
</a>
