<form @submit.prevent="buyNow">
  <div class="px-5 py-4 text-t-primary">
    {% if product.variants.length > 1 %}
      <div class="mb-4 pb-4 border-b border-white/[0.06]">
        <label for="variant" class="block mb-2 text-sm font-semibold uppercase tracking-wider text-t-primary/70">Variant</label>
        {% if properties.variant_selector == 'dropdown' or is_embed %}
          <select name="variant" @change="() => activeVariant = $event.target.value" class="bg-white/[0.025] text-t-primary text-sm py-2.5 px-4 w-full">
            <template x-for="(variant, index) in product.variants" :key="index">
              <option
                :value="index"
                :selected="activeVariant == index"
                x-text="variant.name + ' (' + appCurrency.format(variant.price, product.currency) + ')'"
              ></option>
            </template>
          </select>
        {% else %}
          <div class="flex flex-col gap-2">
            {% for variant in product.variants %}
              <button
                type="button"
                class="flex items-center justify-between gap-4 px-4 py-2.5 transition-all duration-200 ease-out border text-t-primary bg-none border-transparent rounded-lux-sm"
                :class="`${activeVariant == {{ loop.index0 }} ? 'bg-lux-blue/10 !border-lux-blue/30' : 'bg-none border-transparent'} ${({{ 'true' if variant.stock === 0 else 'false' }} || activeVariant == {{ loop.index0 }}) ? '' : 'hover:bg-white/[0.04]'}`"
                @click="() => activeVariant = {{ loop.index0 }}"
                {{ 'title="Out of Stock"' if variant.stock === 0 }}
                {{ 'disabled' if variant.stock === 0 }}
              >
                <div class="flex-1 flex flex-col items-start gap-1 text-left">
                  <p class="text-base">{{ variant.name }}</p>
                  {% if variant.description %}
                    <p class="mb-1 text-xs text-t-primary/50">
                      <span class="whitespace-pre-line">{{ variant.description }}</span>
                    </p>
                  {% endif %}
                  <p class="text-xs text-t-primary/75">
                    {% if variant.stock === 0 %}
                      <span>Out of Stock</span>
                    {% elif product.hide_stock_count %}
                      <span>In Stock</span>
                    {% elif variant.stock === -1 %}
                      <span class="inline-flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="text-lux-blue-light size-4" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
                        In Stock
                      </span>
                    {% else %}
                      <span>{{ variant.stock }} In Stock</span>
                    {% endif %}
                  </p>
                </div>
                <div class="bg-white/[0.04] text-t-primary text-sm px-2.5 py-1 rounded-lux-sm">
                  <span x-text="appCurrency.format({{ variant.price }}, '{{ product.currency }}')">
                    {{ formatPrice(variant.price, product.currency) }}
                  </span>
                  {% if variant.price_slash %}
                    <span class="text-xs text-t-primary/50 line-through">
                      <span x-text="appCurrency.format({{ variant.price_slash }}, '{{ product.currency }}')">
                        {{ formatPrice(variant.price_slash, product.currency) }}
                      </span>
                    </span>
                  {% endif %}
                </div>
              </button>
            {% endfor %}
          </div>
        {% endif %}
        <small x-show="!(activeVariant in product.variants)" x-cloak class="text-lux-error">
          Please select a variant.
        </small>
      </div>
    {% endif %}

    <div class="mb-4 pb-4 border-b border-white/[0.06]">
      <label for="quantity" class="block mb-2 text-sm font-semibold uppercase tracking-wider text-t-primary/70">Quantity</label>
      <div class="flex overflow-hidden rounded-lux-sm focus-within:border-lux-blue/40 focus-within:ring-2 focus-within:ring-lux-blue/20 border border-white/[0.06]">
        <button
          @click="changeQuantity(quantity - 1)"
          type="button"
          class="bg-white/5 hover:bg-lux-blue/20 hover:text-lux-blue-light size-[36px] flex justify-center items-center transition-colors duration-200 ease-out disabled:pointer-events-none disabled:opacity-50"
          :disabled="outOfStock || quantity <= minQuantity"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 12h-15"
            />
          </svg>
        </button>
        <input
          type="number"
          class="w-[calc(100%-72px)] bg-white/[0.025] text-t-primary text-sm focus:outline-none py-2 px-4 disabled:opacity-50"
          name="quantity"
          x-model.number="quantity"
          :min="minQuantity"
          :max="maxQuantity"
          :disabled="outOfStock"
        />
        <button
          @click="changeQuantity(quantity + 1)"
          type="button"
          class="bg-white/5 hover:bg-lux-blue/20 hover:text-lux-blue-light size-[36px] flex justify-center items-center transition-colors duration-200 ease-out disabled:pointer-events-none disabled:opacity-50"
          :disabled="outOfStock || quantity >= maxQuantity"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 4.5v15m7.5-7.5h-15"
            />
          </svg>
        </button>
      </div>

      <small
        x-show="!outOfStock && (quantity < minQuantity || quantity > maxQuantity)"
        x-cloak
        class="text-red-500"
      >
        Please enter a valid quantity (from <span x-text="minQuantity"></span> to <span x-text="maxQuantity"></span>).
      </small>

      <div
        x-show="nextVolumeDiscount"
        class="transition-opacity"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
      >
        <div class="bg-lux-blue/5 text-t-primary/60 text-center text-sm p-2 mt-2 w-full rounded-lux-sm border border-lux-blue/10">
          Buy <span x-text="(nextVolumeDiscount?.quantity - quantity) || 0"></span> more to get a <span x-text="(nextVolumeDiscount?.percentage) || 0"></span>% discount.
        </div>
      </div>
    </div>

    {% if productAddons and productAddons.length > 0 %}
      <div class="mb-4 pb-4 border-b border-white/[0.06]">
        <label class="block mb-2 text-sm font-semibold uppercase tracking-wider text-t-primary/70">Addons</label>
        <div class="flex flex-col gap-2">
          {% for addon in productAddons %}
            <div class="flex items-center justify-between gap-4 px-4 py-2.5 transition-all duration-200 ease-out border text-t-primary bg-white/[0.025] border-white/[0.06] rounded-lux-sm hover:bg-white/[0.04]">
              <div class="flex-1 flex items-center gap-2 text-left">
                {% if addon.image_urls and addon.image_urls[0] %}
                  <img 
                    src="{{ addon.image_urls[0] }}" 
                    alt="{{ addon.name }}"
                    class="-ml-2 size-12 object-cover border border-white/[0.06] rounded-lux-sm"
                  >
                {% endif %}
                <div>
                  <p class="text-base">{{ addon.name }}</p>
                  {% if addon.description %}
                    <p class="mb-1 text-xs text-t-primary/50">
                      <span class="whitespace-pre-line">{{ addon.description }}</span>
                    </p>
                  {% endif %}
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="bg-white/[0.04] text-t-primary text-sm px-2.5 py-1 rounded-lux-sm">
                  <span x-text="appCurrency.format('{{ addon.variants[0].price }}', '{{ addon.currency }}')" class="font-medium">
                    {{ formatPrice(addon.variants[0].price, addon.currency) }}
                  </span>
                </div>
                <button
                  type="button"
                  x-show="!appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                  x-on:click="appCart.add({{ addon.id }}, {{ addon.variants[0].id }}, 1, variant.id)"
                  class="min-w-28 px-4 py-1.5 flex justify-center items-center gap-1 border text-sm font-medium bg-lux-blue/10 text-lux-blue-light border-lux-blue/20 hover:enabled:bg-lux-blue/20 transition-colors duration-200 ease-out disabled:opacity-50 disabled:pointer-events-none rounded-lux-sm"
                  :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
                >
                  <span>Add</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M11 13H6q-.425 0-.712-.288T5 12t.288-.712T6 11h5V6q0-.425.288-.712T12 5t.713.288T13 6v5h5q.425 0 .713.288T19 12t-.288.713T18 13h-5v5q0 .425-.288.713T12 19t-.712-.288T11 18z"/></svg>
                </button>
                {% if addon.is_mandatory %}
                  <button
                    type="button"
                    x-show="appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                    class="min-w-28 px-4 py-1.5 flex justify-center items-center gap-1 border text-sm font-medium bg-lux-blue/10 text-lux-blue-light border-lux-blue/20 rounded-lux-sm"
                    disabled
                    title="This addon is mandatory"
                  >
                    <span>Added</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                  </button>
                {% else %}
                  <button
                    type="button"
                    x-show="appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                    x-on:click="appCart.remove({{ addon.variants[0].id }}, variant.id)"
                    class="min-w-28 px-4 py-1.5 flex justify-center items-center gap-1 border text-sm font-medium bg-lux-error/10 border-lux-error/20 text-lux-error hover:enabled:bg-lux-error/20 transition-colors duration-200 ease-out disabled:opacity-50 disabled:pointer-events-none rounded-lux-sm"
                    :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
                  >
                    <span>Remove</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
                  </button>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if quantity_deals and quantity_deals.length %}
      <div class="mb-4 pb-4 border-b border-white/[0.06]">
        <label class="block mb-2 text-sm font-semibold uppercase tracking-wider text-t-primary/70">Quantity Deals</label>
        <div class="flex flex-col gap-2">
          {% for deal in quantity_deals %}
            {% set bundleSize = deal.buy_quantity + deal.discounted_quantity %}
            <div
              class="flex items-center justify-between gap-3 bg-white/[0.025] border border-white/[0.06] px-4 py-3 rounded-lux-sm"
              {% if deal.variant_id %}
                x-show="variant.id === {{ deal.variant_id }}"
                x-cloak
              {% endif %}
            >
              <div class="flex flex-col gap-1 flex-1 min-w-0">
                <p class="text-sm font-medium text-t-primary truncate">{{ deal.name }}</p>
                <p class="text-xs text-t-primary/70">
                  {% if deal.percentage == 100 %}
                    Buy {{ deal.buy_quantity }}{% if deal.variant_name %} {{ deal.variant_name }}{% endif %}, get {{ deal.discounted_quantity }} free
                  {% else %}
                    Buy {{ deal.buy_quantity }}{% if deal.variant_name %} {{ deal.variant_name }}{% endif %}, get {{ deal.discounted_quantity }} at {{ deal.percentage }}% off
                  {% endif %}
                  {% if deal.max_uses_per_cart %}
                    &nbsp;&middot;&nbsp;Max {{ deal.max_uses_per_cart }}&times; per order
                  {% endif %}
                  {% if deal.ends_at %}
                    &nbsp;&middot;&nbsp;<span class="text-t-primary/40">Ends {{ deal.ends_at | formatDate }}</span>
                  {% endif %}
                </p>
              </div>
              <div class="flex flex-col items-center gap-1.5 flex-shrink-0">
                <span class="lux-badge">
                  {% if deal.percentage == 100 %}FREE{% else %}-{{ deal.percentage }}%{% endif %}
                </span>
                <button
                  type="button"
                  x-show="quantity < {{ bundleSize }}"
                  @click="changeQuantity({{ bundleSize }})"
                  class="text-xs text-lux-blue-light hover:underline whitespace-nowrap"
                >
                  Buy {{ bundleSize }}
                </button>
                <span
                  x-show="quantity >= {{ bundleSize }}"
                  x-cloak
                  class="flex items-center gap-1 text-xs text-lux-blue-light font-medium whitespace-nowrap"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-3" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                  Active
                </span>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if bundle_offers and bundle_offers.length %}
      <script>
        window.__bundleOffers = {{ bundle_offers | json }};
      </script>
      <div class="mb-4 pb-4 border-b border-white/[0.06]">
        <label class="block mb-2 text-sm font-semibold uppercase tracking-wider text-t-primary/70">Bundle Offers</label>
        <div class="flex flex-col gap-3">
          {% for offer in bundle_offers %}
            <div class="flex flex-col gap-3 bg-white/[0.025] border border-white/[0.06] px-4 py-3 rounded-lux-sm">
              <div class="flex items-center justify-between gap-2">
                <span class="text-sm font-semibold text-t-primary">{{ offer.name }}</span>
                {% if offer.ends_at %}
                  <span class="text-xs text-t-primary/40 flex-shrink-0">Ends {{ offer.ends_at | formatDate }}</span>
                {% endif %}
              </div>
              <p class="text-xs text-t-primary/70">
                {% if offer.type == "percentage" %}
                  Save {{ offer.discount }}% when you add all items
                {% else %}
                  Save <span x-text="appCurrency.format({{ offer.discount }}, '{{ product.currency }}')">{{ formatPrice(offer.discount, product.currency) }}</span> when you add all items
                {% endif %}
                {% if offer.max_uses_per_cart %}
                  &nbsp;&middot;&nbsp;Max {{ offer.max_uses_per_cart }}&times; per order
                {% endif %}
              </p>
              <ul class="flex flex-col gap-2">
                {% for item in offer.items %}
                  <li class="flex items-center gap-3 text-t-primary">
                    {% if item.image_url %}
                      <img src="{{ item.image_url }}" alt="{{ item.name }}" class="size-8 object-cover flex-shrink-0">
                    {% else %}
                      <div class="size-8 bg-white/5 flex-shrink-0"></div>
                    {% endif %}
                    <div class="flex-1 min-w-0">
                      {% if item.path and not item.is_current %}
                        <a href="/product/{{ item.path }}" class="text-xs font-medium hover:text-lux-blue-light transition-colors duration-200 ease-out truncate block">
                          {{ item.name }}{% if item.quantity > 1 %} &times;{{ item.quantity }}{% endif %}
                        </a>
                      {% else %}
                        <span class="text-xs font-medium truncate block">
                          {{ item.name }}{% if item.quantity > 1 %} &times;{{ item.quantity }}{% endif %}
                        </span>
                      {% endif %}
                    </div>
                    {% if item.is_current %}
                      <span x-show="appCart.isInCart(variant.id)" class="flex items-center gap-1.5 text-xs text-lux-blue-light font-medium flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-3" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                        In cart
                        <button type="button" @click="appCart.remove(variant.id); addedToCart = false" class="text-t-primary/30 hover:text-red-400 transition-colors duration-200 leading-none">&times;</button>
                      </span>
                      <span x-show="!appCart.isInCart(variant.id)" class="text-xs text-t-primary/40 flex-shrink-0">This item</span>
                    {% elif item.type == 'variant' %}
                      <span x-show="appCart.isInCart({{ item.id }})" x-cloak class="flex items-center gap-1.5 text-xs text-lux-blue-light font-medium flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-3" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                        In cart
                        <button type="button" @click="appCart.remove({{ item.id }})" class="text-t-primary/30 hover:text-red-400 transition-colors duration-200 leading-none">&times;</button>
                      </span>
                      <button
                        type="button"
                        x-show="!appCart.isInCart({{ item.id }})"
                        @click="appCart.add({{ item.product_id }}, {{ item.id }}, {{ item.quantity }})"
                        class="text-xs font-medium text-lux-blue-light border border-lux-blue/30 px-1.5 py-0.5 flex-shrink-0 hover:bg-lux-blue/10 transition-colors duration-200 ease-out rounded-lux-sm"
                      >+ Add</button>
                    {% elif item.variants and item.variants[0] %}
                      <span x-show="appCart.isInCart({{ item.variants[0].id }})" x-cloak class="flex items-center gap-1.5 text-xs text-lux-blue-light font-medium flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-3" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                        In cart
                        <button type="button" @click="appCart.remove({{ item.variants[0].id }})" class="text-t-primary/30 hover:text-red-400 transition-colors duration-200 leading-none">&times;</button>
                      </span>
                      <button
                        type="button"
                        x-show="!appCart.isInCart({{ item.variants[0].id }})"
                        @click="appCart.add({{ item.id }}, {{ item.variants[0].id }}, {{ item.quantity }})"
                        class="text-xs font-medium text-lux-blue-light border border-lux-blue/30 px-1.5 py-0.5 flex-shrink-0 hover:bg-lux-blue/10 transition-colors duration-200 ease-out rounded-lux-sm"
                      >+ Add</button>
                    {% elif item.path %}
                      <a href="/product/{{ item.path }}" class="text-xs font-medium text-lux-blue-light border border-lux-blue/30 px-1.5 py-0.5 flex-shrink-0 hover:bg-lux-blue/10 transition-colors duration-200 ease-out rounded-lux-sm">View</a>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
              <div>
                <button
                  type="button"
                  x-show="!isBundleComplete({{ offer.id }})"
                  @click="addBundleItems({{ offer.id }})"
                  class="w-full px-4 py-2 flex justify-center items-center gap-2 border text-sm font-semibold border-lux-blue/30 text-lux-blue-light hover:bg-lux-blue/10 transition-colors duration-200 ease-out rounded-lux-sm"
                >
                  Add all to cart
                </button>
                <div
                  x-show="isBundleComplete({{ offer.id }})"
                  x-cloak
                  class="flex items-center justify-center gap-2 text-sm text-lux-blue-light py-2"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                  All bundle items in cart
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if altcha and not properties.hide_buy_now %}
      <div
        x-cloak
        x-show="!altchaPayload"
        class="transition-opacity"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
      >
        <altcha-widget
          challengejson='{{ altcha | json }}'
          auto="onload"
          hidefooter="true"
          hidelogo="true"
          x-ref="altcha"
        ></altcha-widget>
      </div>
    {% endif %}

    <div
      x-cloak
      x-show="buyNowError"
      class="transition-opacity"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
    >
      <div class="bg-lux-error/10 border border-lux-error/30 text-lux-error p-4 mt-4 rounded-lux-sm">
        <span x-text="buyNowError"></span>
      </div>
    </div>

    <div class="flex flex-col gap-4 mt-4 lg:flex-row">
      {% if not properties.hide_add_to_cart %}
        <button
          type="button"
          x-on:click="addToCart"
          class="btn-primary flex-1 text-base"
          :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
        >
          <template x-if="!addingToCart && !addedToCart">
            <span class="inline-flex justify-center items-center gap-4">
              <span x-text="cartLimitReached ? 'Cart Limit Reached' : 'Add to Cart'"></span>
              <i class="fa fa-cart-plus"></i>
            </span>
          </template>
          <template x-if="addingToCart">
            <span class="inline-flex justify-center items-center gap-4">
              <span>Adding...&nbsp;&nbsp;</span>
              <i class="fa fa-circle-notch animate-spin"></i>
            </span>
          </template>
          <template x-if="addedToCart">
            <span class="inline-flex justify-center items-center gap-4">
              <span>Go to Cart</span>
              <i class="fa fa-arrow-right"></i>
            </span>
          </template>
        </button>
      {% endif %}
      {% if not properties.hide_buy_now %}
        <button
          type="submit"
          class="btn-outline flex-1 text-base"
          :disabled="outOfStock || product.visibility == 'on_hold' || buyingNow || buyNowDisabled"
        >
          <span>Buy Now</span>
          <template x-if="!buyingNow">
            <i class="fa fa-angles-right"></i>
          </template>
          <template x-if="buyingNow">
            <i class="fa fa-circle-notch animate-spin"></i>
          </template>
        </button>
      {% endif %}
    </div>
  </div>
</form>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productForm', () => ({
      product: {{ product | json }},
      productAddons: {{ productAddons | json }},
      quantityDeals: {{ (quantity_deals or []) | json }},
      activeVariant: 0,
      quantity: {{ product.quantity_min or 1 }},
      isEmbed: {{ 'true' if is_embed else 'false' }},
      addingToCart: false,
      addedToCart: false,
      buyingNow: false,
      buyNowError: null,
      buyNowDisabled: false,
      altchaPayload: null,

      get variant() {
        return this.product.variants[this.activeVariant];
      },

      init: function () {
        const urlParams = new URLSearchParams(window.location.search);

        // Prefill variant from URL parameter if present.
        if (urlParams.has('variant')) {
          const variantIndex = this.product.variants.findIndex(variant => variant.name === urlParams.get('variant'));
          if (variantIndex !== -1) {
            this.activeVariant = variantIndex;
          }
        } else {
          // Choose the first variant that has stock.
          for (let i = 0; i < this.product.variants.length; i++) {
            if (this.product.variants[i].stock !== 0) {
              this.activeVariant = i;
              break;
            }
          }
        }

        if (this.variant.quantity_min) {
          this.quantity = this.variant.quantity_min;
        }

        if (urlParams.has('quantity')) {
          const urlQuantity = parseInt(urlParams.get('quantity'));
          if (!isNaN(urlQuantity) && urlQuantity >= this.minQuantity && urlQuantity <= this.maxQuantity) {
            this.quantity = urlQuantity;
          }
        }

        this.$watch('activeVariant', (newVal, oldVal) => {
          const oldVariant = this.product.variants[oldVal];
          if (oldVariant) {
            for (const addon of this.productAddons) {
              if (!addon.is_mandatory) {
                this.appCart.remove(addon.variants[0].id, oldVariant.id);
              }
            }
          }

          this.quantity = this.product.quantity_min || 1;

          if (this.variant.quantity_min) {
            this.quantity = this.variant.quantity_min;
          }

          this.addedToCart = false;

          for (const addon of this.productAddons) {
            if (addon.is_mandatory) {
              if (!this.appCart.isInCart(addon.variants[0].id, this.variant.id)) {
                this.appCart.add(addon.id, addon.variants[0].id, 1, this.variant.id);
              }
            }
          }
        });

        this.$watch('quantity', () => {
          this.addedToCart = false;
        });

        {% if altcha and not properties.hide_buy_now %}
          this.addAltchaEventListener();
        {% endif %}

        window.addEventListener('pageshow', (event) => {
          if (event.persisted) {
            this.buyingNow = false;
          }
        });
      },

      get nextVolumeDiscount() {
        if (this.variant.volume_discounts) {
          const volumeDiscounts = [...this.variant.volume_discounts].sort((a, b) => a.quantity - b.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (this.quantity < parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      getAppliedVolumeDiscount: function (quantity = null) {
        if (quantity === null) {
          quantity = this.quantity;
        }

        if (this.variant.volume_discounts) {
          const volumeDiscounts = [...this.variant.volume_discounts].sort((a, b) => b.quantity - a.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (quantity >= parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      get unitPrice() {
        const quantity = 1;

        let price = this.variant.price * quantity;

        // Apply volume discounts
        const appliedVolumeDiscount = this.getAppliedVolumeDiscount(quantity);
        if (appliedVolumeDiscount) {
          price = price - (this.variant.price * parseInt(appliedVolumeDiscount.percentage) / 100);
        }

        // Format the price to have 2 decimal places
        const formattedPrice = price.toFixed(2);

        return formattedPrice;
      },

      get totalPrice() {
        let price = this.variant.price * this.quantity;
        let priceBeforeDiscounts = price;

        // Apply volume discounts
        const appliedVolumeDiscount = this.getAppliedVolumeDiscount();
        if (appliedVolumeDiscount) {
          price -= (priceBeforeDiscounts * parseInt(appliedVolumeDiscount.percentage) / 100);
        }

        // Apply quantity deal discounts
        for (const deal of this.quantityDeals) {
          if (deal.variant_id !== null && deal.variant_id !== this.variant.id) continue;
          const bundleSize = deal.buy_quantity + deal.discounted_quantity;
          let applications = Math.floor(this.quantity / bundleSize);
          if (deal.max_uses_per_cart !== null) {
            applications = Math.min(applications, deal.max_uses_per_cart);
          }
          if (applications > 0) {
            price -= applications * deal.discounted_quantity * this.variant.price * (deal.percentage / 100);
          }
        }

        // Append prices of addons
        if (this.appCart.items.length > 0) {
          for (const item of this.appCart.items) {
            if (item.parentVariantId === this.variant.id) {
              const addonVariant = this.productAddons.find(addon => addon.id === item.productId && addon.variants.some(variant => variant.id === item.variantId));
              if (addonVariant) {
                const addonPrice = addonVariant.variants.find(variant => variant.id === item.variantId).price;
                price += addonPrice * item.quantity;
              }
            }
          }
        }

        // If price is negative, set it to 0
        if (price < 0) {
          price = 0;
        }

        // Format the price to have 2 decimal places
        const formattedPrice = price.toFixed(2);

        return formattedPrice;
      },

      get outOfStock() {
        if (this.variant) {
          if (this.variant.stock === 0) {
            return true;
          }

          if (this.variant.quantity_min > 0 && this.variant.stock !== -1 && !this.product.hide_stock_count && this.variant.stock < this.variant.quantity_min) {
            return true;
          }
        }

        return false;
      },

      get minQuantity() {
        const min = this.variant.quantity_min || 1;

        if (this.variant.stock === 0) {
          return 0;
        }

        return min;
      },

      get maxQuantity() {
        const max = this.variant.quantity_max || 999999;

        if (this.variant.stock === 0) {
          return 0;
        }

        if (this.product.hide_stock_count) {
          return max;
        }

        if (this.variant.stock === -1) {
          return max;
        }

        return Math.min(max, this.variant.stock);
      },

      changeQuantity: function (quantity) {
        const min = this.minQuantity;
        const max = this.maxQuantity;
        const newQuantity = Math.min(Math.max(min, quantity), max);

        this.quantity = newQuantity;
      },

      isBundleComplete: function (offerId) {
        const offer = window.__bundleOffers?.find(o => o.id === offerId);
        if (!offer) return false;
        return offer.items.every(item => {
          const required = item.quantity || 1;
          if (item.is_current) {
            const entry = this.appCart.items.find(i => i.variantId === this.variant.id && !i.parentVariantId);
            return entry && entry.quantity >= required;
          }
          if (item.type === 'variant') {
            const entry = this.appCart.items.find(i => i.variantId === item.id && !i.parentVariantId);
            return entry && entry.quantity >= required;
          }
          if (item.variants?.[0]) {
            const entry = this.appCart.items.find(i => i.variantId === item.variants[0].id && !i.parentVariantId);
            return entry && entry.quantity >= required;
          }
          return this.appCart.items.some(i => i.productId === item.id && !i.parentVariantId);
        });
      },

      addBundleItems: function (offerId) {
        const offer = window.__bundleOffers?.find(o => o.id === offerId);
        if (!offer) return;
        for (const item of offer.items) {
          if (item.is_current) {
            if (!this.appCart.isInCart(this.variant.id)) {
              const qty = item.quantity || this.quantity;
              this.quantity = qty;
              this.appCart.add(this.product.id, this.variant.id, qty);
              this.addedToCart = true;
            }
            continue;
          }
          if (item.type === 'variant' && !this.appCart.isInCart(item.id)) {
            this.appCart.add(item.product_id, item.id, item.quantity);
          } else if (item.type === 'product' && item.variants?.[0]) {
            const variantId = item.variants[0].id;
            if (!this.appCart.isInCart(variantId)) {
              this.appCart.add(item.id, variantId, item.quantity);
            }
          }
        }
      },

      get cartLimitReached() {
        const nonAddonItemsCount = this.appCart.items
          .filter(item => !item.parentVariantId)
          .length;

        return nonAddonItemsCount >= {{ shop.max_cart_limit }};
      },

      addToCart: function () {
        if (this.addedToCart) {
          window.location.href = '{{ '/cart' | shopUrl }}';
          return;
        }

        if (this.quantity < this.minQuantity || this.quantity > this.maxQuantity) {
          this.quantity = Math.min(Math.max(this.minQuantity, this.quantity), this.maxQuantity);
        }

        this.addingToCart = true;

        const productId = this.product.id;
        const variantId = this.variant.id;
        const quantity = this.quantity;

        this.appCart.add(productId, variantId, quantity);

        setTimeout(() => {
          this.addedToCart = true;
          this.addingToCart = false;
        }, 500);
      },

      addAltchaEventListener: function () {
        this.$refs.altcha.addEventListener('statechange', (event) => {
          if (event.detail.state === 'verifying') {
            this.buyNowDisabled = true;
          } else if (event.detail.state === 'verified') {
            this.buyNowDisabled = false;
            this.altchaPayload = event.detail.payload;
          }
        });
      },

      generateRecaptchaToken: async function () {
        return new Promise((resolve) => {
          grecaptcha.ready(
            () =>
              void (async () => {
                const token = await grecaptcha.execute(
                  '{{ shop.recaptcha_key }}',
                  { action: 'buynow_s{{ shop.id }}' },
                );

                resolve(token);
              })(),
          );
        });
      },

      buyNow: async function () {
        if (this.buyingNow) {
          return;
        }

        if (this.quantity < this.minQuantity || this.quantity > this.maxQuantity) {
          this.buyNowError = `Please enter a valid quantity (from ${this.minQuantity} to ${this.maxQuantity}).`;
          return;
        }

        const buyNowCart = [{
          productId: this.product.id,
          variantId: this.variant.id,
          quantity: this.quantity,
        }];

        if (this.appCart.items.length > 0) {
          for (const item of this.appCart.items) {
            if (item.parentVariantId === this.variant.id) {
              buyNowCart.push({
                productId: item.productId,
                variantId: item.variantId,
                parentVariantId: item.parentVariantId,
                quantity: item.quantity,
              });
            }
          }
        }

        const formData = {
          cart: buyNowCart,
          currency: this.appCurrency.currency,
          shopId: '{{ shop.id }}',
        };

        if (window.shopCustomer?.email) {
          formData.email = window.shopCustomer.email;
        }

        {% if altcha %}
          if (this.altchaPayload) {
            formData.altcha = this.altchaPayload;
          }
        {% elif shop.recaptcha_key %}
          try {
            formData.recaptchaToken = await this.generateRecaptchaToken();
          } catch (error) {
            this.buyNowError = 'reCAPTCHA cannot be loaded. Please refresh the page and turn off any ad blockers.';
            this.buyingNow = false;
            return;
          }
        {% endif %}

        try {
          this.buyingNow = true;

          const response = await fetch('{{ '/v1/checkout' | apiInternalUrl }}', {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          });

          const responseData = await response.json();

          if (responseData.url) {
            this.checkoutUrl = responseData.url;

            // Open in new tab if we're in an embed.
            if (this.isEmbed) {
              window.open(this.checkoutUrl, '_blank');
            } else {
              window.location.href = this.checkoutUrl;
            }
          } else {
            this.buyingNow = false;
            this.buyNowError = responseData?.message || 'Error in the AJAX request.';

            if (responseData?.error == 'captcha_verification_failed') {
              setTimeout(() => window.location.reload(), 1000);
            }
          }
        } catch (error) {
          console.error(error);
          this.buyingNow = false;
          this.buyNowError = 'Unexpected error. Please refresh the page and try again.';
        }
      }
    }));
  });
</script>

<script>
  window.addEventListener('load', () => {
    if (document.querySelector('select[name="variant"]')) {
     new Choices('select[name="variant"]', { searchPlaceholderValue: 'Search for a variant...', shouldSort: false });
    }
  });
</script>