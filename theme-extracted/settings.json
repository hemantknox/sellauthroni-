{
    "templates": {
        "shop": {
            "layout": "master",
            "components": {
                "hero": {
                    "type": "hero",
                    "properties": {
                        "title": "Welcome to <span class=\"text-accent-500\">{{ shop.name }}</span>!",
                        "subtitle": "{{ shop.description }}",
                        "show_searchbar": true,
                        "buttons": [
                            {
                                "text": "View Products",
                                "icon": "fas fa-cart-shopping",
                                "link": "/products",
                                "new_tab": false,
                                "style": "outline"
                            }
                        ],
                        "alignment": "center",
                        "height": "short",
                        "text_width": "medium",
                        "side_image": null
                    }
                },
                "categories": {
                    "type": "categories",
                    "properties": {
                        "title": "Browse Categories",
                        "centered": true
                    }
                },
                "stats": {
                    "type": "stats",
                    "properties": {
                        "title": null
                    }
                },
                "products": {
                    "type": "products",
                    "properties": {
                        "title": null,
                        "show_searchbar": false,
                        "ids": [],
                        "centered": true
                    }
                },
                "features": {
                    "type": "features",
                    "properties": {
                        "title": null,
                        "subtitle": null,
                        "features": [
                            {
                                "title": "Instant Delivery",
                                "description": "We provide instant delivery for all of our producs to ensure the best experience for our customers.",
                                "icon": "fas fa-truck"
                            },
                            {
                                "title": "Secure Payments",
                                "description": "We use the latest technology to ensure that your payments are secure and your data is safe.",
                                "icon": "fas fa-shield"
                            },
                            {
                                "title": "24/7 Support",
                                "description": "Our support team is available 24/7 to help you with any questions or issues you might have.",
                                "icon": "fas fa-clock"
                            },
                            {
                                "title": "Huge Selection",
                                "description": "We offer a huge selection of products to ensure that you can find exactly what you need.",
                                "icon": "fas fa-box"
                            }
                        ],
                        "centered": true
                    }
                }
            },
            "components_order": [
                "hero",
                "categories",
                "stats",
                "products",
                "features"
            ]
        },
        "cart": {
            "layout": "master",
            "components": {
                "cart-page": {
                    "type": "cart-page",
                    "properties": []
                }
            },
            "components_order": [
                "cart-page"
            ]
        },
        "products": {
            "layout": "master",
            "components": {
                "products-page": {
                    "type": "products-page",
                    "properties": {
                        "default_title": "Our Products",
                        "category_title": "{{ category.name }} Products"
                    }
                }
            },
            "components_order": [
                "products-page"
            ]
        },
        "product": {
            "layout": "master",
            "components": {
                "product-page": {
                    "type": "product-page",
                    "properties": {
                        "variant_selector": "buttons",
                        "show_feedbacks": true,
                        "feedbacks_amount": 4,
                        "hide_add_to_cart": false,
                        "hide_buy_now": false
                    }
                }
            },
            "components_order": [
                "product-page"
            ]
        },
        "feedback": {
            "layout": "master",
            "components": {
                "feedbacks": {
                    "type": "feedbacks",
                    "properties": {
                        "title": "Customer Reviews",
                        "amount": null
                    }
                }
            },
            "components_order": [
                "feedbacks"
            ]
        },
        "status": {
            "layout": "master",
            "components": {
                "status-page": {
                    "type": "status-page",
                    "properties": []
                }
            },
            "components_order": [
                "status-page"
            ]
        },
        "faq": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "terms": {
            "layout": "master",
            "components": {
                "terms-page": {
                    "type": "terms-page",
                    "properties": []
                }
            },
            "components_order": [
                "terms-page"
            ]
        },
        "privacy-policy": {
            "layout": "master",
            "components": {
                "privacy-policy-page": {
                    "type": "privacy-policy-page",
                    "properties": []
                }
            },
            "components_order": [
                "privacy-policy-page"
            ]
        },
        "refund-policy": {
            "layout": "master",
            "components": {
                "refund-policy-page": {
                    "type": "refund-policy-page",
                    "properties": []
                }
            },
            "components_order": [
                "refund-policy-page"
            ]
        },
        "blog": {
            "layout": "master",
            "components": {
                "blog-posts": {
                    "type": "blog-posts",
                    "properties": {
                        "title": "Our Blog"
                    }
                }
            },
            "components_order": [
                "blog-posts"
            ]
        },
        "blog-post": {
            "layout": "master",
            "components": {
                "blog-post": {
                    "type": "blog-post-page",
                    "properties": []
                }
            },
            "components_order": [
                "blog-post-page"
            ]
        },
        "customer-dashboard": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-invoices": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-tickets": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-ticket": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-balance": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "customer-affiliate": {
            "layout": "master",
            "components": [],
            "components_order": []
        },
        "maintenance": {
            "layout": "master",
            "components": [],
            "components_order": []
        }
    },
    "global": {
        "properties": {
            "accent_color": "#3b82f6",
            "background_color": "#06060c",
            "card_color": "#0b0b11",
            "text_primary_color": "#ffffff",
            "text_accent_color": "#ffffff",
            "font": "Play",
            "snow": false,
            "snow_color": "#ffffff",
            "product_card_image_aspect_ratio": "16/9",
            "product_page_image_aspect_ratio": "16/9",
            "product_image_fit": "cover",
            "group_card_image_aspect_ratio": "16/9",
            "group_image_fit": "cover",
            "blog_card_image_aspect_ratio": "16/9",
            "blog_image_fit": "cover"
        },
        "components": {
            "announcement": {
                "announcements": [
                    {
                        "text": "💥 New Products Available Now!",
                        "link": null,
                        "new_tab": false
                    },
                    {
                        "text": "🔥 Check Our Limited Time Offers!",
                        "link": null,
                        "new_tab": false
                    },
                    {
                        "text": "⌛ What Are You Waiting For? Purchase Now!",
                        "link": null,
                        "new_tab": false
                    }
                ]
            },
            "navbar": {
                "show_shop_name": true,
                "show_logo": true,
                "links": [
                    {
                        "text": "Home",
                        "link": "/",
                        "shape": "regular"
                    },
                    {
                        "text": "Products",
                        "link": "/products",
                        "shape": "regular"
                    },
                    {
                        "text": "Reviews",
                        "link": "/feedback",
                        "shape": "regular"
                    },
                    {
                        "text": "Status",
                        "link": "/status",
                        "shape": "regular"
                    },
                    {
                        "text": "Blog",
                        "link": "/blog",
                        "shape": "regular"
                    }
                ],
                "hide_currency_selector": false,
                "hide_customer_dashboard": false,
                "hide_cart": false
            },
            "footer": {
                "show_shop_name": true,
                "show_logo": false,
                "show_socials": true,
                "copyright": "Copyright © {{ shop.name }} {{ '' | currentYear }}",
                "links": [
                    {
                        "text": "Terms of Service",
                        "link": "/terms-of-service",
                        "new_tab": false
                    },
                    {
                        "text": "Privacy Policy",
                        "link": "/privacy-policy",
                        "new_tab": false
                    },
                    {
                        "text": "Refund Policy",
                        "link": "/refund-policy",
                        "new_tab": false
                    }
                ]
            }
        }
    }
}